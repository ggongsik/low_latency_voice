{
  "version": 6,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "LLVC_BUILD_TESTS": "ON",
        "LLVC_BUILD_BENCHMARKS": "ON",
        "LLVC_BUILD_JUCE_APP": "OFF"
      }
    },
    {
      "name": "juce-local",
      "displayName": "JUCE app with local JUCE checkout",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/juce-local",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "LLVC_BUILD_TESTS": "ON",
        "LLVC_BUILD_BENCHMARKS": "ON",
        "LLVC_BUILD_JUCE_APP": "ON",
        "LLVC_JUCE_DIR": ""
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "juce-local",
      "configurePreset": "juce-local"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
